<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS / iisnode configuration for shared Windows hosts (e.g. site4future.com).
  All incoming HTTP requests are routed to index.js, which runs under iisnode.
  Sensitive paths (node_modules, the submissions data folder, this config,
  and iisnode's own log folder) are hidden from public browsing.
-->
<configuration>
  <system.webServer>

    <handlers>
      <add name="iisnode" path="index.js" verb="*" modules="iisnode" />
    </handlers>

    <!--
      Match the URL path (no leading slash in IIS). Only rewrite when there is no
      matching physical file — so /health reaches Node, real files are served as files.
      Passing the path after index.js/ lets Express see /health (with small middleware).
    -->
    <rewrite>
      <rules>
        <rule name="node-express" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.js/{R:1}" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>

    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment="data" />
          <add segment="iisnode" />
          <add segment="web.config" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <!-- Let Express JSON error bodies pass through instead of being replaced by IIS HTML error pages. -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
